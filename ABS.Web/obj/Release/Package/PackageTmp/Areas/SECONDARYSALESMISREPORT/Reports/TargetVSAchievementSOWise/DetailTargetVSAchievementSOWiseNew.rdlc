                        <Textbox Name="Textbox24">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIf(IsNothing(Fields!TRG_QTYCTN.Value), 0, (Sum(Fields!DLV_QTYCTN.Value) / Sum(Fields!TRG_QTYCTN.Value)) * 100)</Value>
                                  <Style>
                                    <FontSize>9pt</FontSize>
                                    <Format>#,0;(#,0);''</Format>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>=IIF(IIf(IsNothing(Fields!TRG_QTYCTN.Value), 0, (Sum(Fields!DLV_QTYCTN.Value) / Sum(Fields!TRG_QTYCTN.Value)) * 100)&gt;0,"%","")</Value>
                                  <Style>
                                    <FontSize>9pt</FontSize>
                                    <Format>#,0;(#,0);''</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox24</rd:DefaultName>
