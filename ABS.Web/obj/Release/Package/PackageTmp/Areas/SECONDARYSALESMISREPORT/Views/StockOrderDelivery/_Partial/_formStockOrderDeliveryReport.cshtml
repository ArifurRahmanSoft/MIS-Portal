<form novalidate name="fmStockOrderDeliveryReport" id="fmStockOrderDeliveryReport" class="form-horizontal row-border">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">National</label>
                <div class="col-md-6">
                    <select id="ddlNational" class="select2-select-00" ng-disabled="IsDisableNational" ng-readonly="IsReadOnlyNational"
                            ng-model="ngModelNational"
                            name="ddlNational"
                            data-placeholder="--Select National--" ng-click="loadDivisionRecords(); loadBrandByNational()"
                            style="width: 100%" ng-options="ntn.NTNAL_OID as ntn.NTNAL_NAME for ntn in listNational" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlNational.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Division</label>
                <div class="col-md-6">
                    <select id="ddlDivision" class="select2-select-00" ng-disabled="IsDisableDivision" ng-readonly="IsReadOnlyDivision"
                            ng-model="ngModelDivision"
                            name="ddlDivision"
                            data-placeholder="--Select Division--" ng-click="loadRegionRecords()"
                            style="width: 100%" ng-options="div.DIVISION_ID as div.DIVISION_NAME for div in listDivision" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlDivision.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Region</label>
                <div class="col-md-6">
                    <select id="ddlRegion" class="select2-select-00" ng-disabled="IsDisableRegion" ng-readonly="IsReadOnlyRegion"
                            ng-model="ngModelRegion"
                            name="ddlRegion"
                            data-placeholder="--Select Region--" ng-click="loadZoneRecords()"
                            style="width: 100%" ng-options="reg.REGION_ID as reg.REGION_NAME for reg in listRegion" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlRegion.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Zone</label>
                <div class="col-md-6">
                    <select id="ddlZone" class="select2-select-00" ng-disabled="IsDisableZone" ng-readonly="IsReadOnlyZone"
                            ng-model="ngModelZone"
                            name="ddlZone"
                            data-placeholder="--Select Zone--" ng-click="loadDistributorRecords()"
                            style="width: 100%" ng-options="zon.ZONE_ID as zon.ZONE_NAME for zon in listZone" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlZone.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Distributor</label>
                <div class="col-md-6">
                    <select id="ddlDistributor" class="select2-select-00" ng-disabled="IsDisableDistributor" ng-readonly="IsReadOnlyDistributor"
                            ng-model="ngModelDistributor"
                            name="ddlDistributor"
                            data-placeholder="--Select Distributor--"
                            style="width: 100%" ng-options="dis.DIST_ID as dis.DIST_NAME for dis in listDistributor" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlDistributor.$error.required">*</span>
            </div>
        </div>

        <div class="col-md-6">

            @*<div class="form-group">
            <label class="col-md-4 control-label" for="input17">Product Category</label>
            <div class="col-md-6">
                <select id="ddlProductCategory" class="select2-select-00"
                        ng-model="ngmProductCategory"
                        name="ddlProductCategory"
                        data-placeholder="--Select Category--" ng-click="loadBrandByCategory()"
                        style="width: 100%" ng-options="cat.CATEGORYID as cat.CATEGORYNAME for cat in listProductCategory" required>
                    <option></option>
                </select>
            </div>
            <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlDivision.$error.required">*</span>
        </div>*@

            <div class="form-group" ng-show="isBrandGroup">
                <label class="col-md-4 control-label" for="input17">Brand Group</label>
                <div class="col-md-6">
                    <select id="ddlBrandGroup" class="select2-select-00"
                            ng-model="brandGroupId"
                            name="ddlBrandGroup"
                            data-placeholder="--Select Brand Group--" ng-change="loadBrandByNationalBrandGroup()"
                            style="width: 100%" ng-options="grp.BRAND_GROUP_ID as grp.BRAND_GROUP_NAME for grp in listBrandGroup" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmProductTransactionReport.$dirty||submitted) && frmProductTransactionReport.brandGroupId.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product Brand</label>
                <div class="col-md-6">
                    <select id="ddlProductBrand" class="select2-select-00"
                            ng-model="ngModelBrand"
                            name="ddlProductBrand"
                            data-placeholder="--Select Brand--" ng-click="loadProductBrand()"
                            @*data-placeholder="--Select Brand--" ng-click="loadSKURecords()"*@
                            style="width: 100%" ng-options="brnd.BRANDID as brnd.SBRND_NAME for brnd in listBrandListByNational" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ddlDivision.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product</label>
                <div class="col-md-6">
                    <select id="ddlProduct" class="select2-select-00"
                            ng-model="ngModelProduct"
                            name="ddlProduct"
                            data-placeholder="--Select Product--"
                            style="width: 100%" ng-options="prod.PRODUCTOID as prod.PRODUCTNAME for prod in ListSKUBrand" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formUndeliveredStatement.$dirty||submitted) && formUndeliveredStatement.ddlZone.$error.required">*</span>
            </div>
            @*<div style="height:32px;"></div>*@

            <div class="form-group">
                <label class="col-md-4 control-label"> From Date </label>
                <div class="col-md-6">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.dtStartDate.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label"> To Date </label>
                <div class="col-md-6">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.dtEndDate.$error.required">*</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17"> Report Type</label>
                <div class="col-md-10">
                    <input type="radio" ng-model="ReportType" value="PcsParty" id="PcsParty"> <label for="PcsParty" class="control-label" style="font-weight:normal; margin-right:10px">Pcs (Party-Wise)</label>
                    <input type="radio" ng-model="ReportType" value="PcsZone" style="margin-left:136px" id="PcsZone"> <label for="PcsZone" class="control-label" style="font-weight:normal; margin-right:10px">Pcs (Area-Wise)</label><br />
                    <input type="radio" ng-model="ReportType" value="SkuParty" id="SkuParty"> <label for="SkuParty" class="control-label" style="font-weight:normal; margin-right:10px">Pcs-Brand-Sku (Party-Wise)</label>
                    <input type="radio" ng-model="ReportType" value="SkuZone" style="margin-left:70px" id="SkuZone"> <label for="SkuZone" class="control-label" style="font-weight:normal; margin-right:10px">Pcs-Brand-Sku (Area-Wise)</label><br />
                    <input type="radio" ng-model="ReportType" value="CtnSackParty" id="CtnSackParty"> <label for="CtnSackParty" class="control-label" style="font-weight:normal; margin-right:10px">Ctn-Sack (Party-Wise)</label>
                    <input type="radio" ng-model="ReportType" value="CtnSackZone" style="margin-left:100px" id="CtnSackZone"> <label for="CtnSackZone" class="control-label" style="font-weight:normal; margin-right:10px">Ctn-Sack (Area-Wise)</label><br />
                    <input type="radio" ng-model="ReportType" value="CtnSkuParty" id="CtnSkuParty"> <label for="CtnSkuParty" class="control-label" style="font-weight:normal; margin-right:10px">CTN-Brand-Sku (Party-Wise)</label>
                    <input type="radio" ng-model="ReportType" value="CtnSkuZone" style="margin-left:65px" id="CtnSkuZone"> <label for="CtnSkuZone" class="control-label" style="font-weight:normal; margin-right:10px">CTN-Brand-Sku (Area-Wise)</label><br />
                    <input type="radio" ng-model="ReportType" value="MtParty" id="MtParty"> <label for="MtParty" class="control-label" style="font-weight:normal; margin-right:10px">MT-Brand-Sku (Party-Wise)</label>
                    <input type="radio" ng-model="ReportType" value="MtZone" style="margin-left:73px" id="MtZone"> <label for="MtZone" class="control-label" style="font-weight:normal; margin-right:10px">MT-Brand-Sku (Area-Wise)</label>
                </div>
                <span class="error" ng-show="(fmStockOrderDeliveryReport.$dirty||submitted) && fmStockOrderDeliveryReport.ReportType.$error.required">*</span>
            </div>
        </div>
    </div>

</form>
