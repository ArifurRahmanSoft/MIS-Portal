                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ActualMinAfterDayHour">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIF(Fields!scham_chno.Value = "", "", 



Format(

Floor(

((DateDiff("n",Fields!dodt.Value, Fields!chdt.Value))/60)/24 

),"00"

) 

+ " day(s)"

+ " " +

Format(

Floor(

(DateDiff("n",Fields!dodt.Value, Fields!chdt.Value))/60 MOD 24

),"00"

) 

+ " hour(s)"


+ " " +

Format(

Floor(

DateDiff("n",Fields!dodt.Value, Fields!chdt.Value) MOD 60

),"00"

) 

+ " min(s)"


)</Value>
                                  <Style>
                                    <FontSize>8pt</FontSize>
                                    <Format>0;(0)</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Center</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>ActualMinAfterDayHour</rd:DefaultName>
                          <Style>
                            <Border>
                              <Color>LightGrey</Color>
                              <Style>Solid</Style>
                            </Border>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
