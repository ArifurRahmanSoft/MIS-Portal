<form novalidate name="formDepotStockByRate" id="formDepotStockByRate" class="form-horizontal row-border">

    <input type="hidden" id="menuID" readonly="readonly" ng-model="MenuID" />

    <div class="row">
        <div class="col-md-6">

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Company</label>
                <div class="col-md-6">
                    <select id="ddlCompany" class="select2-select-00" ng-disabled="IsDisableCompany"
                            ng-model="ngModelCompany"
                            name="ddlCompany"
                            data-placeholder="--Select Company--"
                            style="width: 100%" ng-options="com.SCOMP_OID as com.SCOMP_NAME for com in listCompany" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.ddlZone.$error.required">*</span>
            </div>


            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Location</label>
                <div class="col-md-6">
                    <select id="ddlLocation" class="select2-select-00"
                            ng-model="ngModelLocation"
                            name="ddlLocation"
                            data-placeholder="--Select Location--"
                            style="width: 100%" ng-options="loc.SGLOC_ID as loc.SGLOC_NAME for loc in listLocation" required>
                        <option></option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product Brand</label>
                <div class="col-md-6">
                    <select id="ddlProductBrand" class="select2-select-00"
                            ng-model="ngModelBrand"
                            name="ddlProductBrand"
                            data-placeholder="--Select Brand--" ng-click="loadProductBrand()"
                            style="width: 100%" ng-options="brnd.BRANDID as brnd.SBRND_NAME for brnd in listBrand">
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.ddlDivision.$error.required">*</span>
            </div>
            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product</label>
                <div class="col-md-6">
                    <select id="ddlProduct" class="select2-select-00"
                            ng-model="ngModelProduct"
                            name="ddlProduct"
                            data-placeholder="--Select Product--"
                            style="width: 100%" ng-options="prod.PRODUCTOID as prod.PRODUCTNAME for prod in ListSKUBrand" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.ddlZone.$error.required">*</span>
            </div>


            <div class="form-group">
                <label class="col-md-4 control-label">From Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.dtStartDate.$error.required">*</span>
            </div>
            <div class="form-group">
                <label class="col-md-4 control-label">To Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.dtEndDate.$error.required">*</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17"> Report Type</label>
                <div class="col-md-10">
                    @*<input type="radio" ng-model="ReportType" value="Details">Details
        &nbsp;  &nbsp; &nbsp;*@
                    <input type="radio" ng-model="ReportType" value="Depots">By SKU
                    &nbsp;  &nbsp; &nbsp;
                    <input type="radio" ng-model="ReportType" value="Brand">By Brand
                    &nbsp;  &nbsp; &nbsp;
                    <input type="radio" ng-model="ReportType" value="ProductMrps">By Product MRP
                    @*&nbsp;  &nbsp; &nbsp;
                    <input type="radio" ng-model="ReportType" value="SKUs">*@
                </div>
                <span class="error" ng-show="(formDepotStockByRate.$dirty||submitted) && formDepotStockByRate.ReportType.$error.required">*</span>
            </div>
        </div>
    </div>


</form>
