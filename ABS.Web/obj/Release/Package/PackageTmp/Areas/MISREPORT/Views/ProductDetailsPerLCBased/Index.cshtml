@{
    ViewBag.Title = "MIS REPORT";
}
<div ng-controller="tokenCtrl">
    <div class="container" ng-controller="ProductDetailsPerLCBasedCtrl">
        <div ng-controller="BreadcrumbCtrl">
            @Html.Partial("~/Areas/SystemCommon/Views/Shared/_Partial/_Breadcrumbs.cshtml")
        </div>
        <div class="page-header">
        </div>        
        <div class="row">
            <div class="col-md-12">
                @Html.Partial("~/Areas/SystemCommon/Views/WaitModal/_modalWait.cshtml")
            </div>
        </div>

        <div id="PIDiv">
            <div class="row">
                <div class="col-md-12">
                    <div class="widget box">
                        <div class="widget-header">
                            <h4><i class="icon-reorder"></i> {{CustomerWiseDeliveryPageTitle}}</h4>
                            <div class="toolbar no-padding">
                                <span id="reset" class="btn btn-danger margin-right-btn" ng-click="clearReportPart()">
                                    <i class="icon-refresh"></i> Reset
                                </span>
                                <span id="save" class="btn btn-success margin-right-btn" ng-click="ShowProductDetailsPerLCBased()"
                                      ng-disabled="IsShowReportButtonDisabled">
                                    <i class="icon-save"></i> Show Report
                                </span>
                                <span class="btn btn-xs widget-collapse"><i class="icon-angle-down"></i></span>
                            </div>
                        </div>
                        <div class="widget-content" id="frmEntry">
                            @Html.Partial("~/Areas/MISREPORT/Views/ProductDetailsPerLCBased/_Partial/_formProductDetailsPerLCBased.cshtml")
                        </div>
                    </div>
                </div>
            </div>

            <div class="row" ng-hide="IsHidden">
                <div class="col-md-12">
                    <div class="widget box">
                        <div class="widget-header">
                            <h4><i class="icon-reorder"></i> {{ListTitleRequisitionMaster}}</h4>
                            <div class="toolbar no-padding">
                                <div class="btn-group">
                                </div>
                            </div>
                        </div>
                        <div class="widget-content no-padding">
                            @Html.Partial("~/Areas/MISREPORT/Views/ProductDetailsPerLCBased/_Partial/_tableProductDetailsPerLCBased.cshtml")
                        </div>
                    </div>
                    <div class="clearfix"></div>
                </div> <!-- /.col-md-12 -->
            </div>
        </div>
    </div>
</div>
    <!-- /.container -->
    @section AngularScript{
        <script src="~/Areas/MISREPORT/ScriptsNg/Controllers/ProductDetailsPerLCBasedCtrl.js"></script>
        <script src="~/Areas/MISREPORT/ScriptsNg/Service/CrudService.js"></script>
        <script src="~/Areas/MISREPORT/ScriptsNg/Directives/Conversion.js"></script>
        <script src="~/Scripts/CustomToastrMessage.js"></script>
        <script src="~/Areas/SystemCommon/ScriptsNg/Controllers/BreadcrumbCtrl.js"></script>
        <script src="~/Areas/Token/TokenController.js"></script>
    }
