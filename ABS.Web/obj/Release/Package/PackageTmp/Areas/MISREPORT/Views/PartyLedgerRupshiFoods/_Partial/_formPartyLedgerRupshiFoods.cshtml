<form novalidate name="formPartyLedgerRupshiFoods" id="formPartyLedgerRupshiFoods" class="form-horizontal row-border">

    <input type="hidden" id="menuID" readonly="readonly" ng-model="MenuID" />

    <div class="row">
        <div class="col-md-6">

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Company</label>
                <div class="col-md-6">
                    <select id="ddlCompany" class="select2-select-00" ng-disabled="IsDisableCompany"
                            ng-model="ngModelCompany"
                            name="ddlCompany"
                            data-placeholder="--Select Company--"
                            style="width: 100%" ng-options="com.SCOMP_OID as com.SCOMP_NAME for com in listUserWiseCompany" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formBulkCustomerWiseDelivery.$dirty||submitted) && formBulkCustomerWiseDelivery.ddlZone.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Distributor</label>
                <div class="col-md-6">
                    <select id="ddlDistributor" class="select2-select-00" ng-disabled="IsDisableDistributor" ng-readonly="IsReadOnlyDistributor"
                            ng-model="ngModelDistributor"
                            name="ddlDistributor"
                            data-placeholder="--Select Customer--"
                            style="width: 100%" ng-options="dis.DIST_ID as dis.DIST_NAME for dis in listDistributor" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formBulkCustomerWiseDelivery.$dirty||submitted) && formBulkCustomerWiseDelivery.ddlDistributor.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product Group</label>
                <div class="col-md-6">
                    <select id="ddlProductGroup" class="select2-select-00"
                            ng-model="ngModelProductGroup"
                            name="ddlProductGroup"
                            data-placeholder="--Select Product Group--"
                            style="width: 100%" ng-options="pg.SPROG_ID as pg.SPROG_NAME for pg in listProductGroup" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formBulkCustomerWiseDelivery.$dirty||submitted) && formBulkCustomerWiseDelivery.ddlProductGroup.$error.required">*</span>
            </div>

        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label">From Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(formPartyLedger.$dirty||submitted) && formPartyLedger.dtStartDate.$error.required">*</span>
            </div>
            <div class="form-group">
                <label class="col-md-4 control-label">To Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(formPartyLedger.$dirty||submitted) && formPartyLedger.dtEndDate.$error.required">*</span>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17">Report Type</label>
                <div class="col-md-10">
                    <input type="radio" id="101" ng-model="ReportType" value="1"><label for="101" style="font-weight:normal">&nbsp;Details </label>
                    <input type="radio" id="102" ng-model="ReportType" value="2"><label for="102" style="font-weight: normal">&nbsp;Summary </label>
                    <input type="radio" id="103" ng-model="ReportType" value="3"><label for="103" style="font-weight: normal">&nbsp;Details(Extra)</label>

                </div>
                @* <span class="error" ng-show="(frmBrandWiseSalesStatement.$dirty||submitted) && frmBrandWiseSalesStatement.ddlZone.$error.required">*</span>*@
            </div>
        </div>
    </div>
</form>
