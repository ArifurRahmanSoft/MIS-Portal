<table class="table table-hover right-bottom-scroll-m">
    <thead class="grid-top-panel">
        <tr>
            <th>DISTRIBUTOR</th>
            <th>BRAND</th>
            <th>TARGET QUANTITY</th>
            <th>PRIMARY SALE QUANTITY</th>
            <th>SECONDARY SALE QUANTITY</th>
            <th>Unit</th>
        </tr>
    </thead>
    <tbody>
        <tr ng-repeat="dataModel in listIncenCalTarPriSecon">
            <td>{{dataModel.DISTRIBUTORID}}</td>
            <td>{{dataModel.BRANDID}}</td>
            <td>{{dataModel.TARGETQUANTITY}}</td>
            <td>{{dataModel.PRIMARYSALEQUANTITY}}</td>
            <td>{{dataModel.SECONDARYSALEQUANTITY}}</td>
            <td>M.Ton</td>
        </tr>
    </tbody>
    <tfoot></tfoot>
</table>
<p ng-show="(listIncenCalTarPriSecon).length == 0" style="color:red">No Data found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>