<form novalidate name="frmOrganogram" id="organogram" class="form-horizontal row-border">

    <div class="form-group">
        <label class="col-md-1 control-label" for="input17">Sales Team</label>
        <div class="col-md-11">
            <select id="ddlNational" class="select2-select-00" ng-disabled="IsDisableNational" ng-readonly="IsReadOnlyNational"
                    ng-model="ngModelNational"
                    name="ddlNational"
                    data-placeholder="--Select Sales Team--" ng-change="ResetBrandPermission()"
                    style="width: 100%" ng-options="ntn.NTNAL_OID as ntn.NTNAL_NAME for ntn in listNational" required>
                <option></option>
            </select>
        </div>
        <span class="error" ng-show="(frmBrandWiseSalesStatement.$dirty||submitted) && frmBrandWiseSalesStatement.ddlNational.$error.required">*</span>
    </div>

    <div class="form-group">
        <label class="col-md-1 control-label" for="input17">Product Category</label>
        <div class="col-md-11">
            <select id="ddlProductCategory" class="select2-select-00"
                    ng-model="ngmProductCategory"
                    name="ddlProductCategory"
                    data-placeholder="--Select Category--" ng-click="loadBrandByCategory()"
                    style="width: 100%" ng-options="cat.CATEGORYID as cat.CATEGORYNAME for cat in listProductCategory" required>
                <option></option>
            </select>
        </div>
        <span class="error" ng-show="(frmBrandWiseSalesStatement.$dirty||submitted) && frmBrandWiseSalesStatement.ddlDivision.$error.required">*</span>
    </div>

    <div class="form-group">
        <label class="col-md-1 control-label" for="input17">Product Brand</label>
        <div class="col-md-11">
            <select id="ddlProductBrand" class="select2-select-00"
                    ng-model="ngmProductBrand"
                    name="ddlProductBrand"
                    data-placeholder="--Select Brand--"
                    style="width: 100%" ng-options="brnd.BRANDID as brnd.SBRND_NAME for brnd in listBrand" required>
                <option></option>
            </select>
        </div>
        <span class="error" ng-show="(frmBrandWiseSalesStatement.$dirty||submitted) && frmBrandWiseSalesStatement.ddlDivision.$error.required">*</span>
    </div>

</form>
