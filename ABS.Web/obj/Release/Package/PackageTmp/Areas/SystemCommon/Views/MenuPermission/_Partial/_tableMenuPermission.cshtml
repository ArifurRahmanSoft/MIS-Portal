
<input id="custSearch" ng-model="custSearch" type="text" class="form-control search" placeholder="Search...">
<table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
    <thead class="grid-top-panel">
        <tr>
            <th class="text-center col-md-1">SN.</th>
            <th class="text-center col-md-6">Menu</th>
            <th class="text-center">View</th>
            <th class="text-center">Insert</th>
            <th class="text-center">Update</th>
            <th class="text-center">Delete</th>
            @*<th class="text-center col-md-1" id="chkEnableAllView"><input type="checkbox" class="uniform" ng-model="EnableAllView" ng-click="EnableAllViewClicked(EnableAllView)" />   View  </th>
            <th class="text-center col-md-1" id="chkEnableAllInsert"><input type="checkbox" class="uniform" ng-model="EnableAllInsert" ng-click="EnableAllInsertClicked(EnableAllInsert)" /> Insert</th>
            <th class="text-center col-md-1" id="chkEnableAllUpdate"> <input type="checkbox" class="uniform" ng-model="EnableAllUpdate" ng-click="EnableAllUpdateClicked(EnableAllUpdate)" /> Update</th>
            <th class="text-center col-md-1" id="chkEnableAllDelete"> <input type="checkbox" class="uniform" ng-model="EnableAllDelete" ng-click="EnableAllDeleteClicked(EnableAllDelete)" /> Delete</th>*@
        </tr>
    </thead>
    <tbody>
        <tr ng-repeat="dataModel in ListPermission | filter:custSearch">
            <td class="col-md-1">{{$index+1}}</td>
            <td class="col-md-6">{{dataModel.MENUNAME}}</td>
            <td class="checkbox-column col-md-1">
                <div><span><input type="checkbox" ng-model="dataModel.ENABLE_VIEW" ng-click="gridViewCheckBoxClicked($index, dataModel.ENABLE_VIEW)"></span></div>
            </td>
            <td class="checkbox-column col-md-1 ">
                <div><span><input type="checkbox" ng-model="dataModel.ENABLE_INSERT" ng-click="gridInsertCheckBoxClicked($index, dataModel.ENABLE_INSERT)"></span></div>
            </td>
            <td class="checkbox-column col-md-1">
                <div><span><input type="checkbox" ng-model="dataModel.ENABLE_UPDATE" ng-click="gridUpdateCheckBoxClicked($index, dataModel.ENABLE_UPDATE)"></span></div>
            </td>
            <td class="checkbox-column col-md-1">
                <div>
                    <span>
                    <input type="checkbox" ng-model="dataModel.ENABLE_DELETE" ng-click="gridDeleteCheckBoxClicked($index, dataModel.ENABLE_DELETE)">
                    </span>
                </div>
            </td>
        </tr>
    </tbody>
</table>
<p ng-show="(ListPermission | filter:custSearch).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>
