<form novalidate name="frmLineProductMapping" id="frmLineProductMapping" class="form-horizontal row-border">

    <div class="row">
        <div class="col-md-4">

            <div class="form-group">
                <label class="col-md-3 control-label" for="input17">Sales Group</label>
                <div class="col-md-8">
                    <select id="SDVNT_OID" class="select2-select-00"
                            ng-model="SDVNT_OID"
                            name="SDVNT_OID" ng-change="onChangeSdvnt()"
                            data-placeholder="--Select Sales Group--"
                            style="width: 100%" ng-options="sdv.SDVNT_OID as sdv.SDVNT_NAME for sdv in sdvntList">
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmLineProductMapping.$dirty||submitted) && frmLineProductMapping.SDVNT_OID_10.$error.required">*</span>
            </div>

        </div>

        @*<div class="col-md-2">

            <div class="form-group">
                <div class="checkbox-column col-md-8">
                    <input id="ntnalEn" type="checkbox" ng-model="IS_ENABLE">&nbsp;<label class="control-label" for="ntnalEn">Is Active</label>
                </div>
                <span class="error" ng-show="(frmLineProductMapping.$dirty||submitted) && frmLineProductMapping.ntnalEn.$error.required">*</span>
            </div>
        </div>*@

        <div class="col-md-2">
            <div class="form-group pull-right">
                <span id="load" class="btn btn-info margin-right-btn" ng-click="loadList()">
                    <i class="icon-refresh"></i> {{isShowList? "Load Detail":"Load Master"}}
                </span>
            </div>
        </div>
    </div>   

</form>

<div class="row" ng-show="!isShowList && ListLineProduct.length>0">
    <div class="col-md-12">
        <input id="custSearch" ng-model="custSearch" type="text" class="form-control search" placeholder="Search...">
        <table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
            <thead class="grid-top-panel">
                <tr>
                    <th class="text-center col-md-1">SL.</th>
                    <th class="text-center col-md-1">Check</th>
                    <th class="text-center col-md-2">PRODUCT CODE</th>
                    <th class="text-center col-md-4">PRODUCT NAME</th>
                    <th class="text-center col-md-2">BRAND NAME</th>
                    <th class="text-center col-md-2">GROUP NAME</th>
                </tr>
            </thead>
            <tbody style="text-align:center;">
                <tr ng-repeat="dataModel in ListLineProduct | filter:custSearch">
                    <td class="col-md-1">{{$index+1}}</td>
                    <td class="checkbox-column col-md-1 ">
                        <div><span><input ng-disabled="dataModel.IS_EXIST" type="checkbox" ng-model="dataModel.IS_CHECKED"></span></div>
                    </td>
                    <td class="col-md-2">{{dataModel.PROD_CODE}}</td>
                    <td class="col-md-4">{{dataModel.PROD_NAME}}</td>
                    <td class="col-md-2">{{dataModel.BRAND_NAME}}</td>
                    <td class="col-md-2">{{dataModel.SDVNT_NAME}}</td>                    
                </tr>
            </tbody>
        </table>
        <p ng-show="(ListLineProduct | filter:custSearch).length == 0" style="color:red">Nothing found!</p>

        <div class="loadmore">
            <div ng-show="loaderMore" ng-class="result">
                {{lblMessage}}
            </div>
            <div ng-show="scrollended" ng-class="result">
                {{lblMessage}}
            </div>
        </div>
    </div>
</div>
