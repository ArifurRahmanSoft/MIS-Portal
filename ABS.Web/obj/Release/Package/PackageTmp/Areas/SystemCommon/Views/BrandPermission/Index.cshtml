@{
    ViewBag.Title = "Permission List";
}

<div ng-controller="tokenCtrl">
    <div class="container" ng-controller="BrandPermissionCtrl">
        <!-- Breadcrumbs line -->
        <div ng-controller="BreadcrumbCtrl">
            @Html.Partial("~/Areas/SystemCommon/Views/Shared/_Partial/_Breadcrumbs.cshtml")
        </div>
        <!-- /Breadcrumbs line -->
        <!--=== Page Header ===-->
        <div class="page-header">

        </div>
        <!-- /Page Header -->
        <!--=== Page Content ===-->
        <div class="row">
            <div class="col-md-12">
                <div class="widget box">
                    <div class="widget-header">
                        <h4><i class="icon-reorder"></i> {{PageTitle}}</h4>
                        <div class="toolbar no-padding">
                            <div class="btn-group">
                                <input type="button" id="resetTop" style="width:100px;" class="btn btn-facebook margin-right-btn" value="Reset" ng-click="clear()">
                                <input type="button" id="saveTop" style="width:100px;" class="btn btn-success margin-right-btn" value="Save"
                                       ng-click="Save(ListBrandPermission)" ng-disabled=" frmdeliveryorder.$invalid">
                                <span class="btn btn-xs widget-collapse"><i class="icon-angle-down"></i></span>
                            </div>
                        </div>
                    </div>
                    <div class="widget-content">
                        @Html.Partial("~/Areas/SystemCommon/Views/BrandPermission/_Partial/_formBrandPermission.cshtml")
                    </div>
                </div>
            </div> <!-- /.col-md-12 -->
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="widget box">
                    <div class="widget-header">
                        <h4><i class="icon-reorder"></i> {{ListTitle}}</h4>
                        <div class="toolbar no-padding">
                            <div class="btn-group">

                                <input type="button" id="Generate" style="width:300px; margin-right: 350px;" class="btn btn-info margin-right-btn" value="Add to List"
                                       ng-click="AddToList(ddlModule, ListModule)">
                                <span class="btn btn-xs widget-collapse"><i class="icon-angle-down"></i></span>

                            </div>
                        </div>
                    </div>
                    <div class="widget-content no-padding">
                        @Html.Partial("~/Areas/SystemCommon/Views/BrandPermission/_Partial/_tableBrandPermission.cshtml")
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            @Html.Partial("~/Areas/SystemCommon/Views/BrandPermission/_Partial/_tableSKUList.cshtml")
        </div>

    </div>

</div>
<!-- /.container -->
    @section AngularScript{
<script src="~/Areas/SystemCommon/ScriptsNg/Service/CrudService.js"></script>
<script src="~/Areas/SystemCommon/ScriptsNg/Service/menuService.js"></script>
<script src="~/Areas/SystemCommon/ScriptsNg/Controllers/BrandPermissionCtrl.js"></script>
<script src="~/Areas/SystemCommon/ScriptsNg/Controllers/MenuCtrl.js"></script>
<script src="~/Areas/SystemCommon/ScriptsNg/Controllers/BreadcrumbCtrl.js"></script>
<script src="~/Areas/SystemCommon/ScriptsNg/Directives/Conversion.js"></script>
<script src="~/Areas/Token/TokenController.js"></script>
        @*
<script src="~/Areas/Token/TokenController.js"></script>*@
    }
