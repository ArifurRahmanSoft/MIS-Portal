<div class="modal fade" id="ItemModal">
    <div class="modal-dialog modal-dialog-ext" style="width:55% !important;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                <h4 class="modal-title"><i class="icon-folder-open"></i>List of SKU for Brand: {{BrandTitle}} </h4>
            </div>

            <div class="modal-body no-padding">

                <input id="brandSKUSearch" ng-model="brandSKUSearch" type="text" class="form-control search" placeholder="Search...">
                <table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
                    <thead class="grid-top-panel">
                        <tr>
                            <th class="text-center col-md-1">SN.</th>
                            <th class="text-center col-md-2">
                                <input type="checkbox" id="chkEnableAllChecked" class="uniform" ng-model="EnableAllCheck"
                                       ng-click="AllCheckClicked(EnableAllCheck)" /> Check All
                            </th>
                            <th class="text-center col-md-9">Product/SKU Name</th>
                        </tr>
                    </thead>
                    <tbody style="text-align:center;">
                        <tr ng-repeat="dataModel in ListSKUBrand | filter:brandSKUSearch">
                            <td class="col-md-1">{{$index+1}}</td>
                            <td class="checkbox-column col-md-2">
                                <div>
                                    <span>
                                        <input type="checkbox" id="chkEnableSingleCheck" ng-model="dataModel.ENABLE_CHECK"
                                               ng-click="gridViewCheckBoxClicked(dataModel)">
                                    </span>
                                </div>
                            </td>
                            <td ng-show="false">{{dataModel.PRODUCTOID}}</td>
                            <td class="col-md-9">{{dataModel.PRODUCTNAME}}</td>
                        </tr>
                    </tbody>
                </table>

                <p ng-show="(ListSKUBrand | filter:brandSKUSearch).length == 0" style="color:red">Nothing found!</p>

                <div class="loadmore">
                    <div ng-show="loaderMore" ng-class="result">
                        {{lblMessage}}
                    </div>
                    <div ng-show="scrollended" ng-class="result">
                        {{lblMessage}}
                    </div>
                </div>

            </div>
            <div class="modal-footer">

            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->
