<table class="table table-hover right-bottom-scroll-m" style="max-height: 1150px; !important">

    <thead class="grid-top-panel">
        <tr>
            <td style="display:none">ProductOID</td>
            <th>Product Code</th>
            <th>Product Name</th>
            <th>Nos Per Pack</th>
            <th>Weight</th>
            <th>Costing Rate</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        <tr ng-repeat="dataModel in listProduct">

            <td style="display:none">{{dataModel.OID}}</td>
            <td>{{dataModel.SPROD_TEXT}}</td>
            <td>{{dataModel.SPROD_NAME}}</td>
            <td>{{dataModel.NPPK}}</td>
            <td>{{dataModel.SPROD_NPWT}}</td>
            <td>
                <input type="number" id="txtCostingRate" name="txtCostingRate" class="form-control" ng-click="EditAction($event,$index, dataModel)" 
                 ng-keydown="($event.keyCode === 13) && EditAction($event,$index, dataModel)" style="width:100px;"
                 ng-model="dataModel.SPROD_COST_RATE" min="0.00" required />
            </td>
                        
            <td style="text-align:right; color:white">
                <span class="label label-danger label-mini">
                    <a href="javascript:void(0);" data-toggle="modal" class="bs-tooltip" title="Select">
                        <i class="icon-edit" ng-click="Edit($index, dataModel)"></i>
                    </a>
                </span>
            </td>
        </tr>
    </tbody>
    <tfoot></tfoot>
</table>
<p ng-show="(listProduct).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>