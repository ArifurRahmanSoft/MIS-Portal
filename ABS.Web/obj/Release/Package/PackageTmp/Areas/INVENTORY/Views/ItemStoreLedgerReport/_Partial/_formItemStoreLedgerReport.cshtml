
<form novalidate name="formItemStoreLedgerReport" id="formItemStoreLedgerReport" class="form-horizontal row-border">

    <input type="hidden" id="menuID" readonly="readonly" ng-model="MenuID" />

    <div class="row">
        <div class="col-md-6">

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Company/Unit Name</label>
                <div class="col-md-6">
                    <select id="ddlUnit" class="select2-select-00"
                            ng-model="ngModelUnit"
                            name="ddlUnit"
                            data-placeholder="--Select Company--"
                            style="width: 100%" ng-options="unit.CUNIT_ID as unit.CUNIT_NAME for unit in ListUnists" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formPurchaseOrderReport.$dirty||submitted) && formPurchaseOrderReport.ddlUnit.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Item Group</label>
                <div class="col-md-6">
                    <select id="ddlGroup" class="select2-select-00"
                            ng-model="ngItemGroup"
                            name="ddlGroup"
                            data-placeholder="--Select Item Group--"
                            style="width: 100%" ng-options="group.ITMGRP_ID as group.GRP_NAME for group in ListItemGrp" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formPurchaseOrderReport.$dirty||submitted) && formPurchaseOrderReport.ddlUnit.$error.required">*</span>
            </div>


            @*<div class="form-group">
                <label class="col-md-4 control-label" for="input17">Supplier Name</label>
                <div class="col-md-6">
                    <select id="ddlSupplier" class="select2-select-00"
                            ng-model="ngModelSupplier"
                            name="ddlSupplier"
                            data-placeholder="--Select Suppliers--"
                            style="width: 100%" ng-options="supp.SUPP_ID as supp.SUPP_NAME for supp in ListSuppliers" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formPurchaseOrderReport.$dirty||submitted) && formPurchaseOrderReport.ddlSupplier.$error.required">*</span>
            </div>*@

            <div class="form-group">
                <label class="col-md-4 control-label"> Item</label>
                <div class="col-md-5">
                    <input type="text"
                           id="DisplayItemName" style="width:96%; color: blue; font-weight: bold;"
                           class="form-control pull-left" placeholder="Select Item" ng-dblclick="loadSampleNoModalRecords(0)" readonly
                           name="DisplayItemName" ng-model="DisplayItemName" required />
                </div>
                <div class="col-md-1">
                    <button class="label label-primary" style="text-align: center !important; border: none; padding: 5%; margin-left: -50%; margin-top: 0PX;" ng-click="loadSampleNoModalRecords(0)">
                        <i class="icon-search" aria-hidden="true"></i>
                    </button>
                </div>

                <span class="error" ng-show="(formItemPurchaseHistory.$dirty||submitted) && formItemPurchaseHistory.ITEM_ID.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label"> From Date </label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(formPurchaseOrderReport.$dirty||submitted) && formPurchaseOrderReport.dtStartDate.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label"> To Date </label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(formPurchaseOrderReport.$dirty||submitted) && formPurchaseOrderReport.dtEndDate.$error.required">*</span>
            </div>

        </div>

        <div class="col-md-6">

        </div>
    </div>
    <div class="row">
        <div class="col-md-12">
          
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17">Report Type</label>
                <div class="col-md-10">
                    <input type="radio" ng-model="ReportType" value="consummary">Con.Unit Wise (Summary)
                    <input type="radio" ng-model="ReportType" value="condetails">Con.Unit Wise (Details)</br>
                    <input type="radio" ng-model="ReportType" value="itemsummary">Item Wise (Summary)
                    <input type="radio" ng-model="ReportType" value="itemdetails">Item Wise (Details)</br>
                    <input type="radio" ng-model="ReportType" value="itemcusummary">Item In All CU (Summary)
                    <input type="radio" ng-model="ReportType" value="itemdcudetails">Item In All CU (Details) <br />
                    <input type="radio" ng-model="ReportType" value="itemstocksummary">Item Stock For Audit (Summary)
                    <input type="radio" ng-model="ReportType" value="itemstockDetails">Item Stock For Audit (Details)<br />
                    <input type="radio" ng-model="ReportType" value="combinedItem">Combined Item Stock <br />
                    <input type="radio" ng-model="ReportType" value="combinedIssue">Combined Item Issue 
                </div>

            </div>
        </div>
    </div>

</form>
