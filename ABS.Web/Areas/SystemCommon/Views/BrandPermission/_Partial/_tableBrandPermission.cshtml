<input id="custSearch" ng-model="custSearch" type="text" class="form-control search" placeholder="Search...">
<table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
    <thead class="grid-top-panel">
        <tr>
            <th class="text-center col-md-1">SN.</th>
            <th class="text-center col-md-3">Category Name</th>
            <th class="text-center col-md-3">Brand Name</th>
            <th class="text-center col-md-3">SKU List</th>
            <th class="text-center col-md-2">Option</th>
        </tr>
    </thead>
    <tbody style="text-align:center;">
        <tr ng-repeat="dataModel in ListBrandPermission | filter:custSearch">
            <td class="col-md-1">{{$index+1}}</td>
            <td class="col-md-3">{{dataModel.CATEGORYNAME}}</td>
            <td class="col-md-1" ng-show="false">{{dataModel.BRANDOID}}</td>
            <td class="col-md-3">{{dataModel.BRANDNAME}}</td>


            <td class="col-md-3">
                <span class="label label-success label-mini">
                    <a href="javascript:void(0);" ng-click="loadSKURecords(dataModel)" class="bs-tooltip" title="Show SKU List">
                        <i class="icon-search"></i>
                    </a>
                </span>
            </td>


            <td class="col-md-2">
                <span class="label label-danger label-mini">
                    <a href="javascript:void(0);" class="bs-tooltip" title="Delete"
                       ng-click="deleteBrand(dataModel,$index)">
                        <i class="icon-trash"></i>
                    </a>
                </span>
            </td>
        </tr>
    </tbody>
</table>
<p ng-show="(ListPermission | filter:custSearch).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>
