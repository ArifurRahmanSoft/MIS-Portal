
<form novalidate name="frmOrganogram" id="organogram" class="form-horizontal row-border">

    <input type="hidden" id="menuPermissionID " readonly="readonly" ng-model="MenuPermissionID " />

    <div class="form-group">
        <label class="col-md-1 control-label" for="input17"> User</label>
        <div class="col-md-11">
            <select id="userDropDown" class="select2-select-00"
                    ng-model="ddlUserMaster" ng-change="SetInputUser(ddlUserMaster)"
                    name="userDropDown" data-placeholder="--Select User--"
                    style="width: 100%" ng-options="usr.USERID as usr.USERFULLNAME for usr in ListUser">
                <option></option>
            </select>
        </div>
    </div>

    <div class="form-group" ng-controller="menuCtrl">
        <label class="col-md-1 control-label" for="input"> Module</label>
        <div class="col-md-11">
            <select id="moduleDropDown" class="select2-select-00"
                    ng-model="ddlModule" ng-change="SetInputModule(ddlModule)"
                    name="moduleDropDown" data-placeholder="--Select Module--"
                    style="width: 100%" ng-options="mdl.MODULEID as mdl.MODULENAME for mdl in ListModuleForPermission">
                <option></option>
            </select>
        </div>
    </div>
    
</form>
