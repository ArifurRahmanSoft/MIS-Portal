<form novalidate name="formCashTransfer" id="formCashTransfer" class="form-horizontal row-border">


    @*to make the date time .... month/year format*@
    <script type="text/javascript">
        $(function () {
            $(".mydatepicker").datepicker({
                format: "MM-yyyy",
                startView: "months",
                minViewMode: "months",
                autoclose: true
            });
            $(".mydatepicker").datepicker('setDate', new Date());
        });
    </script>

    <div class="row">
        <div class="col-md-12">
            <div class="col-md-6">

