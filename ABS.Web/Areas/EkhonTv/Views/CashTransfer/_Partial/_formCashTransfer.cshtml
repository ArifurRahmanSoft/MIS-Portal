            <label class="col-md-4 control-label">Company</label>
            <div class="col-md-6">
                <select id="ddlCompany" class="select2-select-00" required
                        ng-model="ngmCompany" tabindex="1" disabled
                        name="ddlCompany"
                        data-placeholder="--Select Company--"
                        style="width: 100%"
                        ng-options="company.OID as company.SCOMP_NAME for company in listCompany">
                    <option></option>
                </select>
            </div>
        </div>*@
                <div class="form-group">
                    <label class="col-md-4 control-label">Agent</label>
                    <div class="col-md-6">
                        <select id="ddlAgent" class="select2-select-00" required
                                ng-model="ngmAgent" tabindex="1"
                                name="ddlAgent"
                                data-placeholder="--Select Agent--"
                                style="width: 100%"
                                ng-options="agent.OID as agent.CLIENT_NAME for agent in listAgent">
                            <option></option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-md-4 control-label">Client</label>
                    <div class="col-md-6">
                        <select id="ddlClient" class="select2-select-00" required
                                ng-model="ngmClient" tabindex="1"
                                name="ddlClient"
                                data-placeholder="--Select Client--"
                                style="width: 100%"
                                ng-options="client.OID as client.CLIENT_NAME for client in listClient">
                            <option></option>
                        </select>
                    </div>
                </div>

                @*<div class="form-group">
        <label class="col-md-4 control-label"></label>
        <div class="col-md-6">
            <input type="text"
                   id="dtFromMonth"
                   placeholder="mm-yyyy" class="form-control mydatepicker"
                   name="dtFromMonth" ng-model="ngmFromMonth" required />
        </div>
        <span class="error" ng-show="true"></span>
        </div>*@

