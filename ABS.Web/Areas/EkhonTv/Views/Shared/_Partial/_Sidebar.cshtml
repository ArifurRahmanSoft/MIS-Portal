        <ul id="nav">
            <li>
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="icon-mail-reply-all"></i>
                    Go Back
                </a>
            </li>
            <li ng-repeat="menu in ListMenues" ng-if="menu.ChildMenues.length>0">
                <a href="javascript:void(0);" title="{{menu.MenuName}}">
                    <i class="{{menu.ReportName}}"></i>
                    {{menu.MenuName}}
                    <i class="{{menu.MenuIconCss}}"></i>
                    <span class="label label-info pull-right">{{menu.ChildMenues.length}}</span>
                </a>
                <ul class="sub-menu">
                    <li ng-repeat="menuChild in menu.ChildMenues | filter:custMenuSearch" ng-if="!menuChild.HasChild">
                        <a ng-href="{{menuChild.MenuPath}}" ng-click="SideBarMenuClicked(menuChild,ListMenues,menu.ChildMenues)" title="{{menuChild.MenuName}}">
                            <i class="{{menuChild.MenuIconCss}}"></i>
                            {{menuChild.MenuName}}
                        </a>
                    </li>

                    <li ng-repeat="menuChild in menu.ChildMenues | filter:custMenuSearch" ng-if="menuChild.HasChild">
                        <a href="javascript:void(0);" title="{{menuChild.MenuName}}">
                            <i class="{{menuChild.ReportName}}"></i>
                            {{menuChild.MenuName}}
                            <i class="{{menuChild.MenuIconCss}}"></i>
                            <span class="label label-info pull-right">{{menuChild.ChildMenues.length}}</span>
                        </a>

                        <ul class="sub-menu">
                            <li ng-repeat="smenuChild in menuChild.ChildMenues | filter:custMenuSearch">
                                <a ng-href="{{smenuChild.MenuPath}}" ng-click="SideBarMenuClicked(smenuChild,ListMenues,menu.ChildMenues)" title="{{smenuChild.MenuName}}">
                                    <i class="{{smenuChild.MenuIconCss}}"></i>
                                    {{smenuChild.MenuName}}
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </li>
        </ul>

        <div ng-show="loaderWait" ng-class="result" class="loadwait">
            <img src="~/Content/img/ng-loader.gif" />
            {{LoadMessage}}
        </div>

        <div class="sidebar-widget align-center">
        </div>

        <div class="sidebar-widget align-center">
            <p style="color:red; font-weight:bold;">Powered by IT, CityGroup</p>
            <p>Copyright &copy; @DateTime.Now.Year</p>
        </div>

    </div>
    <div id="divider" class="resizeable"></div>
</div>
