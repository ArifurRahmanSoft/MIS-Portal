<form novalidate name="frmSRPerformance" id="frmSRPerformance" class="form-horizontal row-border">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">National</label>
                <div class="col-md-6">
                    <select id="ddlNational" class="select2-select-00" ng-disabled="IsDisableNational" ng-readonly="IsReadOnlyNational"
                            ng-model="ngModelNational"
                            name="ddlNational" 
                            data-placeholder="--Select National--" ng-click="loadDivisionRecords(); loadBrandByNational()"
                            style="width: 100%" ng-options="ntn.NTNAL_OID as ntn.NTNAL_NAME for ntn in listNational" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlNational.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Division</label>
                <div class="col-md-6">
                    <select id="ddlDivision" class="select2-select-00" ng-disabled="IsDisableDivision" ng-readonly="IsReadOnlyDivision"
                            ng-model="ngModelDivision"
                            name="ddlDivision"
                            data-placeholder="--Select Division--" ng-click="loadRegionRecords()"
                            style="width: 100%" ng-options="div.DIVISION_ID as div.DIVISION_NAME for div in listDivision" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlDivision.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Region</label>
                <div class="col-md-6">
                    <select id="ddlRegion" class="select2-select-00" ng-disabled="IsDisableRegion" ng-readonly="IsReadOnlyRegion"
                            ng-model="ngModelRegion"
                            name="ddlRegion"
                            data-placeholder="--Select Region--" ng-click="loadZoneRecords()"
                            style="width: 100%" ng-options="reg.REGION_ID as reg.REGION_NAME for reg in listRegion" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlRegion.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Zone</label>
                <div class="col-md-6">
                    <select id="ddlZone" class="select2-select-00" ng-disabled="IsDisableZone" ng-readonly="IsReadOnlyZone"
                            ng-model="ngModelZone"
                            name="ddlZone" 
                            data-placeholder="--Select Zone--" ng-click="loadDistributorRecords()"
                            style="width: 100%" ng-options="zon.ZONE_ID as zon.ZONE_NAME for zon in listZone" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlZone.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Distributor</label>
                <div class="col-md-6">
                    <select id="ddlDistributor" class="select2-select-00" ng-disabled="IsDisableDistributor" 
                            ng-readonly="IsReadOnlyDistributor" ng-click="loadAreaWiseSalesPerson()"
                            ng-model="ngModelDistributor"
                            name="ddlDistributor"
                            data-placeholder="--Select Distributor--"
                            style="width: 100%" ng-options="dis.DIST_ID as dis.DIST_NAME for dis in listDistributor" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlDistributor.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Sales Officer</label>
                <div class="col-md-6">
                    <select id="ddlSalesPerson" class="select2-select-00" 
                            
    @*ng-disabled="IsDisableDistributor" ng-readonly="IsReadOnlyDistributor"*@
                            @*plan for the disable part later*@

                            ng-model="ngModelSalesPerson"
                            name="ddlSalesPerson"
                            data-placeholder="--Select Sales Officer--" 
                            style="width: 100%" ng-options="so.SO_TEXT as so.SO_NAME for so in listSalesPerson" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlSalesPerson.$error.required">*</span>
            </div>

        </div>

        <div class="col-md-6">

            <div class="form-group" ng-show="isBrandGroup">
                <label class="col-md-4 control-label" for="input17">Brand Group</label>
                <div class="col-md-6">
                    <select id="ddlBrandGroup" class="select2-select-00"
                            ng-model="brandGroupId"
                            name="ddlBrandGroup"
                            data-placeholder="--Select Brand Group--" ng-change="loadBrandByNationalBrandGroup()"
                            style="width: 100%" ng-options="grp.BRAND_GROUP_ID as grp.BRAND_GROUP_NAME for grp in listBrandGroup" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmProductTransactionReport.$dirty||submitted) && frmProductTransactionReport.brandGroupId.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product Brand</label>
                <div class="col-md-6">
                    <select id="ddlProductBrand" class="select2-select-00"
                            ng-model="ngModelBrand"
                            name="ddlProductBrand"
                            data-placeholder="--Select Brand--" ng-click="loadProductBrand()"
                            style="width: 100%" ng-options="brnd.BRANDID as brnd.SBRND_NAME for brnd in listBrandListByNational" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.ddlDivision.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Product</label>
                <div class="col-md-6">
                    <select id="ddlProduct" class="select2-select-00"
                            ng-model="ngModelProduct"
                            name="ddlProduct"
                            data-placeholder="--Select Product--"
                            style="width: 100%" ng-options="prod.PRODUCTOID as prod.PRODUCTNAME for prod in ListSKUBrand" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(formUndeliveredStatement.$dirty||submitted) && formUndeliveredStatement.ddlZone.$error.required">*</span>
            </div>
            @*<div style="height:32px;"></div>*@

            <div class="form-group">
                <label class="col-md-4 control-label"> From Date </label>
                <div class="col-md-6">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.dtStartDate.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label"> To Date </label>
                <div class="col-md-6">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(frmSRPerformance.$dirty||submitted) && frmSRPerformance.dtEndDate.$error.required">*</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17"> Report Type</label>
                <div class="col-md-10">
                    <input type="radio" id="Summary" ng-model="ReportType" value="Summary"><label for="Summary" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Summary(Value)</label>
                    <input type="radio" id="Detail" ng-model="ReportType" value="Detail"><label for="Detail" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Detail(Value)</label>
                    <input type="radio" id="SR_Delivery_Summary" ng-model="ReportType" value="SR_Delivery_Summary"><label for="SR_Delivery_Summary" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Delivery Summary</label>
                    <input type="radio" id="SR_Delivery_Detail" ng-model="ReportType" value="SR_Delivery_Detail"><label for="SR_Delivery_Detail" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Delivery Detail(Brand)</label>
                    <input type="radio" id="SR_Delivery_Detail_Sku" ng-model="ReportType" value="SR_Delivery_Detail_Sku"><label for="SR_Delivery_Detail_Sku" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Delivery SKU-Wise</label>
                    <input type="radio" id="SR_Delivery_Detail_Dist" ng-model="ReportType" value="SR_Delivery_Detail_Dist"><label for="SR_Delivery_Detail_Dist" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Delivery Dist-Wise</label>

                    <input type="radio" id="SR_Order_Summary" ng-model="ReportType" value="SR_Order_Summary"><label for="SR_Order_Summary" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Order Summary</label>
                    <input type="radio" id="SR_Order_Detail" ng-model="ReportType" value="SR_Order_Detail"><label for="SR_Order_Detail" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Order Detail(Brand)</label>
                    <input type="radio" id="SR_Order_Detail_Sku" ng-model="ReportType" value="SR_Order_Detail_Sku"><label for="SR_Order_Detail_Sku" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Order SKU-Wise</label>
                    <input type="radio" id="SR_Order_Detail_Dist" ng-model="ReportType" value="SR_Order_Detail_Dist"><label for="SR_Order_Detail_Dist" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Order Dist-Wise</label>

                </div>
                <span class="error" ng-show="(frmTargetVSAchievementSOWise.$dirty||submitted) && frmTargetVSAchievementSOWise.ReportType.$error.required">*</span>
            </div>
        </div>
    </div>

</form>
