<input id="custSearch" ng-model="custSearch" type="text" class="form-control search" placeholder="Search...">
<table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
    <thead class="grid-top-panel">
        <tr>
            <th class="text-center col-md-1">SN.</th>
            <th class="text-center col-md-2">BRAND_NAME</th>
            <th class="text-center col-md-1">PRODUCT_CODE</th>
            <th class="text-center col-md-4">PRODUCT_NAME</th>
            <th class="text-center col-md-1">BAG/CARTON</th>
            <th class="text-center col-md-1">DP_PCS</th>
            <th class="text-center col-md-1">DP_CTN</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">TP_PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">TP_CTN</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">MRP_PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">MRP_CTN</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">SWP_PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">SWP_CTN</th>
            <th class="text-center col-md-2">Option</th>
        </tr>
    </thead>
    <tbody style="text-align:center;">
        <tr ng-repeat="dataModel in ListBrandSkuAdded | filter:custSearch">
            <td class="col-md-1">{{$index+1}}</td>

            <td class="col-md-1" ng-show="false">{{dataModel.BRANDOID}}</td>
            <td class="col-md-2">{{dataModel.SBRND_NAME}}</td>
            <td class="col-md-1" ng-show="false">{{dataModel.PRODUCTOID}}</td>
            <td class="col-md-1">{{dataModel.PRODUCT_CODE}}</td>
            <td class="col-md-4">{{dataModel.PRODUCTNAME}}</td>
            <td class="col-md-1">{{dataModel.PACKSIZE}}</td>
            <td class="col-md-1">{{dataModel.DP_PCS}}</td>
            <td class="col-md-1">{{dataModel.DP_CTN}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.TP_PCS}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.TP_CTN}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.MRP_PCS}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.MRP_CTN}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.SWP_PCS}}</td>
            <td class="col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">{{dataModel.SWP_CTN}}</td>

            <td class="col-md-2">
                <span class="label label-danger label-mini">
                    <a href="javascript:void(0);" class="bs-tooltip" title="Delete"
                       ng-click="deleteItem(dataModel,$index)">
                        <i class="icon-trash"></i>
                    </a>
                </span>
            </td>
        </tr>
    </tbody>
</table>
<p ng-show="(ListPermission | filter:custSearch).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>
