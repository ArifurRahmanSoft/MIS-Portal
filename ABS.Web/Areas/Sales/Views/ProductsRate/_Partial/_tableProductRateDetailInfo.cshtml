@*<table class="table table-hover right-bottom-scroll-m">*@
<table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">

    <thead class="grid-top-panel">
        <tr>
            <th class="text-center col-md-1">PRODUCT CODE</th>
            <th class="col-md-4">PRODUCT NAME</th>
            <th class="text-center col-md-1">BAG/CARTON</th>
            <th class="text-center col-md-1">DP PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">TP PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">MRP PCS</th>
            <th class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">SWP PCS</th>
        </tr>
    </thead>
    <tbody>
        <tr ng-repeat="dataModel in ListProductByBrand">
            <td ng-show="false">BRANDOID</td>
            <td ng-show="false">PACKSIZE</td>
            <td ng-show="false">PRODUCTOID</td>
            <td ng-show="false">SBRND_NAME</td>
            <td ng-show="false">{{dataModel.BRAND_ID}}</td>
            <td class="text-center col-md-1">{{dataModel.PRODUCT_CODE}}</td>
            <td class="col-md-4">{{dataModel.PRODUCTNAME}}</td>
            <td class="text-center col-md-1">1 X {{dataModel.PACKSIZE}}</td>
            <td class="text-center col-md-1">
                <input type="number" id="txtDPPCS" name="txtDPPCS" class="form-control" style="width:100px;"
                       ng-model="dataModel.DP_PCS" min="0.00" required />
            </td>
            <td class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">
                <input type="number" id="txtTPPCS" name="txtTPPCS" class="form-control" style="width:100px;"
                       ng-model="dataModel.TP_PCS" min="0.00" required />
            </td>
            <td class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">
                <input type="number" id="txtMRPPCS" name="txtMRPPCS" class="form-control" style="width:100px;"
                       ng-model="dataModel.MRP_PCS" min="0.00" required />
            </td>
            <td class="text-center col-md-1" ng-show="sstypId=='SSTYPxxxxxxxxxxxx04' && ngModelBrand!='SBRNDxxxxxxxxxx00201'?false:true">
                <input type="number" id="txtSWPPCS" name="txtSWPPCS" class="form-control" style="width:100px;"
                       ng-model="dataModel.SWP_PCS" min="0.00" required />
            </td>
        </tr>
    </tbody>
    <tfoot></tfoot>
</table>
<p ng-show="(ListProductByBrand).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>