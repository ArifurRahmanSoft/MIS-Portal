<table class="table table-hover right-bottom-scroll-m">
    <thead class="grid-top-panel">
        <tr>
            <th>Distributor</th>
            <th>Brand</th>
            <th>Brand Name</th>
            <th>Sales Force</th>          
            <th>Incentive Amount(Tk.)</th>
        </tr>
    </thead>
    <tbody>
        <tr ng-repeat="dataModel in listIncenCalculation">
            <td>{{dataModel.DISTRIBUTORID}}</td>
            <td>{{dataModel.BRANDID}}</td>
            <td>{{dataModel.SBRND_NAME}}</td>
            <td>{{dataModel.SALES_FORCE_TYPE_ID}}</td>
            <td>{{dataModel.ACTUALINCENTIVE}}</td>
        </tr>
    </tbody>
    <tfoot></tfoot>
</table>
<p ng-show="(listIncenCalculation).length == 0" style="color:red">No Data found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>