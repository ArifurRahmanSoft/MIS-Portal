<form novalidate name="frmCardConsumerDataUpload" id="frmCardConsumerDataUpload" class="form-horizontal row-border">
    <div class="row">

        <div class="col-md-3">
            <div class="form-group">
                <label class="col-md-5 control-label"> Start Date </label>
                <div class="col-md-6">
                    <input type="text" autocomplete="off"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" />
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-group">
                <label class="col-md-4 control-label">End Date</label>
                <div class="col-md-6">
                    <input type="text" autocomplete="off"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" />
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-group">
                <label class="col-md-5 control-label">Distributor ID</label>
                <div class="col-md-6">
                    <input type="text"
                           id="txtDistributorID"
                           class="form-control"
                           name="txtDistributorID" ng-model="ngDistributorID" />
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-group">
                <label class="col-md-5 control-label">Challan No</label>
                <div class="col-md-6">
                    <input type="text"
                           id="txtChallanNo"
                           class="form-control"
                           name="txtChallanNo" ng-model="ngChallanNo" />
                </div>
            </div>
        </div>


        <div class="col-md-3">
            <div class="form-group">
                <div class="col-md-3">
                    <input type="button" id="Generate" style="width:100px; margin-right: 250px;" class="btn btn-info margin-right-btn"
                           value="Show Data" ng-click="ShowCardConsumerReportData()">
                </div>
            </div>
        </div>


    </div>
</form>
