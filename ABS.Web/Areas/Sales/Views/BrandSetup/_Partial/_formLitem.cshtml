<style>
    .sutonny-text {
        font-family: 'SutonnyMJ', 'Arial Unicode MS', sans-serif;
    }
</style>

<form novalidate name="frmMenu" id="lItemForm" class="form-horizontal row-border">
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Product Name</label>
                <div class="col-md-6">
                    <input type="text"
                           id="productName"
                           class="form-control"
                           name="productName" ng-model="lItem.prodName" />
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Bangla Name</label>
                <div class="col-md-6">
                    <input type="text"
                           id="bnName"
                           class="form-control sutonny-text"
                           name="productNames" ng-model="lItem.prodBnName" />
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Product Type </label>
                <div class="col-md-7">
                    <input type="text"
                           id="prodType"
                           class="form-control "
                           name="productCode" ng-model="lItem.prodType"
                          />
                </div>
            @*    <div class="col-md-2">
                    <span id="save" class="btn btn-success margin-right-btn" ng-href="#menuModal" data-toggle="modal" ng-click="GetProductDetails()" ng-disabled="frmExpenseEntry.$invalid">
                        <i class="icon-search"></i> Search
                    </span>

                </div>*@
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Product Group</label>
                <div class="col-md-6">
                    <input type="text"
                           id="prodGroup"
                           class="form-control"
                           name="prodGroup" ng-model="lItem.prodGroup" />
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Product Sub Group</label>
                <div class="col-md-6">
                    <input type="text"
                           id="prodSubGroup"
                           class="form-control"
                           name="prodSubGroup" ng-model="lItem.subGroup" />
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="form-group">
                <label class="col-md-4 control-label">Rate Type </label>
                <div class="col-md-3">
                    <input type="text"
                           id="isActive"
                           class="form-control "
                           name="isActive" ng-model="lItem.rateType"
                           />
                </div>


                <label style="text-align:right" class="col-md-3 control-label text-right">Is Active </label>
                <div class="col-md-1">
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               ng-checked="lItem.isActv === 'Y'"
                               ng-click="toggleIsActive()"
                              
                               id="flexCheckChecked">
                    </div>
                </div>

            </div>





        </div>
    </div>
</form>

