    <div style="max-height: 500px; overflow-y: auto; border: 1px solid #ccc;">
        <table class="table table-striped table-bordered" style="width: 100%; table-layout: fixed; border-collapse: collapse;">
            <thead style="position: sticky; top: 0; background-color: gray; color:white; z-index: 10; box-shadow: 0 2px 2px -1px rgba(0,0,0,0.1);">
                <tr>
                    <th style="cursor: pointer; text-align: left; width: 5%;">SELECT</th>
                    <th style="cursor: pointer; text-align: center; width: 25%;">PRODUCT CODE</th>
                    <th style="cursor: pointer; text-align: center; width: 65%;">PRODUCT NAME</th>
                    <th style="cursor: pointer; text-align: center; width: 25%;">PRODUCT SHORT NAME</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="product in listProductDetail">
                    <td data-dismiss="modal" style="text-align: left;" class="form-check pl-2 pr-1 pt-1 pb-1">
                        <input type="checkbox" ng-model="product.selected" ng-change="GetDetailsByProductCode(product)">
                    </td>
                    <td style="cursor: pointer; text-align: center;" class="pl-2 pr-1 pt-1 pb-1">{{product.sprod_text}}</td>
                    <td style="cursor: pointer; text-align: center;" class="pl-2 pr-1 pt-1 pb-1">{{product.sprod_name}}</td>
                    <td style="cursor: pointer; text-align: center;" class="pl-2 pr-1 pt-1 pb-1">{{product.sprod_snam}}</td>
                </tr>
            </tbody>
        </table>
    </div>



</form>
