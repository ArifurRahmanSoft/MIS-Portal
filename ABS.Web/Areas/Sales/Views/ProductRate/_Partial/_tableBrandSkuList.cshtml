<input id="custSearch" ng-model="custSearch" type="text" class="form-control search" placeholder="Search...">
<table class="table table-striped table-bordered table-hover table-checkable table-tabletools datatable dataTable ">
    <thead class="grid-top-panel">
        <tr>
            <th class="text-center col-md-1">SN.</th>
            <th class="text-center col-md-3">BRAND_NAME</th>
            <th class="text-center col-md-3">PRODUCT_NAME</th>
            <th class="text-center col-md-2">BAG/CARTON</th>
            <th class="text-center col-md-2">DP_PCS</th>
            <th class="text-center col-md-2">DP_CTN</th>
            <th class="text-center col-md-2">TP_PCS</th>
            <th class="text-center col-md-2">TP_CTN</th>
            <th class="text-center col-md-2">MRP_PCS</th>
            <th class="text-center col-md-2">MRP_CTN</th>
            <th class="text-center col-md-2">Option</th>
        </tr>
    </thead>
    <tbody style="text-align:center;">
        <tr ng-repeat="dataModel in ListBrandSkuAdded | filter:custSearch">
            <td class="col-md-1">{{$index+1}}</td>

            <td class="col-md-1" ng-show="false">{{dataModel.BRANDOID}}</td>
            <td class="col-md-3">{{dataModel.SBRND_NAME}}</td>
            <td class="col-md-1" ng-show="false">{{dataModel.PRODUCTOID}}</td>
            <td class="col-md-3">{{dataModel.PRODUCTNAME}}</td>
            <td class="col-md-2">{{dataModel.PACKSIZE}}</td>
            <td class="col-md-2">{{dataModel.DP_PCS}}</td>
            <td class="col-md-2">{{dataModel.DP_CTN}}</td>
            <td class="col-md-2">{{dataModel.TP_PCS}}</td>
            <td class="col-md-2">{{dataModel.TP_CTN}}</td>
            <td class="col-md-2">{{dataModel.MRP_PCS}}</td>
            <td class="col-md-2">{{dataModel.MRP_CTN}}</td>

            <td class="col-md-2">
                <span class="label label-danger label-mini">
                    <a href="javascript:void(0);" class="bs-tooltip" title="Delete"
                       ng-click="deleteItem(dataModel,$index)">
                        <i class="icon-trash"></i>
                    </a>
                </span>
            </td>
        </tr>
    </tbody>
</table>
<p ng-show="(ListPermission | filter:custSearch).length == 0" style="color:red">Nothing found!</p>

<div class="loadmore">
    <div ng-show="loaderMore" ng-class="result">
        {{lblMessage}}
    </div>
    <div ng-show="scrollended" ng-class="result">
        {{lblMessage}}
    </div>
</div>
