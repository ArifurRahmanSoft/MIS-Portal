<form novalidate name="frmSMSSending" id="frmSMSSending" class="form-horizontal row-border">
    <input type="hidden" id="OID" readonly="readonly" ng-model="OID" />

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-3 control-label">Your Message:</label>
                <div class="col-md-9">
                    @*<input type=""
                           id="txtMessage" class="form-control"
                           name="txtMessage" ng-model="MESSAGETEXT" />*@

                    <textarea rows="3" cols="5"
                           id="txtMessage" class="form-control"
                           name="txtMessage" ng-model="MESSAGETEXT"></textarea>
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-3 control-label">Mobile Number (11 Digit):</label>
                <div class="col-md-3">
                    <input type="text"
                           id="txtMessage" class="form-control"
                           name="txtMessage" ng-model="MOBILENUMBER" />
                </div>
            </div>
        </div>
    </div>
</form>
