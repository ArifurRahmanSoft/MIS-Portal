<form novalidate name="frmSalesComparison" id="frmSalesComparison" class="form-horizontal row-border">

    <input type="hidden" id="menuID" readonly="readonly" ng-model="MenuID" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label">From Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtStartDate"
                           class="form-control datepicker"
                           name="dtStartDate" ng-model="StartDate" required />
                </div>
                <span class="error" ng-show="(frmSalesComparison.$dirty||submitted) && frmSalesComparison.dtStartDate.$error.required">*</span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label">To Date</label>
                <div class="col-md-3">
                    <input type="text"
                           id="dtEndDate"
                           class="form-control datepicker"
                           name="dtEndDate" ng-model="EndDate" required />
                </div>
                <span class="error" ng-show="(frmSalesComparison.$dirty||submitted) && frmSalesComparison.dtEndDate.$error.required">*</span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17"> Report Type</label>
                <div class="col-md-10">

                    @*<input type="radio" ng-model="ReportType" value="mastergroupbangla">Master Group(Bangla)*@
                    <input type="radio" ng-model="ReportType" value="mastergroup">Master Group
                    <input type="radio" ng-model="ReportType" value="productgroup">Product Group
                    <input type="radio" ng-model="ReportType" value="brandwise">Brand-Wise
                    <input type="radio" ng-model="ReportType" value="skuwise">SKU-Wise

                </div>
                <span class="error" ng-show="(frmSalesComparison.$dirty||submitted) && frmSalesComparison.ReportType.$error.required">*</span>
            </div>
        </div>
    </div>

</form>
