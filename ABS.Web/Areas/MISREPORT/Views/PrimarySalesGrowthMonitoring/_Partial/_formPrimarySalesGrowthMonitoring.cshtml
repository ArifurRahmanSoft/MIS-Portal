<form novalidate name="frmSalesStatement" id="frmSalesStatement" class="form-horizontal row-border">

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Company</label>
                <div class="col-md-6">
                    <select id="ddlCompany" class="select2-select-00" ng-disabled="IsDisableCompany"
                            ng-model="ngModelCompany"
                            name="ddlCompany"
                            data-placeholder="--Select Company--"
                            style="width: 100%" ng-options="com.SCOMP_OID as com.SCOMP_NAME for com in listCompany" required>
                        <option></option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">National</label>
                <div class="col-md-6">
                    <select id="ddlNational" class="select2-select-00" ng-disabled="IsDisableNational" ng-readonly="IsReadOnlyNational"
                            ng-model="ngModelNational"
                            name="ddlNational"
                            data-placeholder="--Select National--" ng-click="loadDivisionRecords(); loadBrandByNational()"
                            style="width: 100%" ng-options="ntn.NTNAL_OID as ntn.NTNAL_NAME for ntn in listNational" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ddlNational.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Division</label>
                <div class="col-md-6">
                    <select id="ddlDivision" class="select2-select-00" ng-disabled="IsDisableDivision" ng-readonly="IsReadOnlyDivision"
                            ng-model="ngModelDivision"
                            name="ddlDivision"
                            data-placeholder="--Select Division--" ng-click="loadRegionRecords()"
                            style="width: 100%" ng-options="div.DIVISION_ID as div.DIVISION_NAME for div in listDivision" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ddlDivision.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Region</label>
                <div class="col-md-6">
                    <select id="ddlRegion" class="select2-select-00" ng-disabled="IsDisableRegion" ng-readonly="IsReadOnlyRegion"
                            ng-model="ngModelRegion"
                            name="ddlRegion"
                            data-placeholder="--Select Region--" ng-click="loadZoneRecords()"
                            style="width: 100%" ng-options="reg.REGION_ID as reg.REGION_NAME for reg in listRegion" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ddlRegion.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Zone</label>
                <div class="col-md-6">
                    <select id="ddlZone" class="select2-select-00" ng-disabled="IsDisableZone" ng-readonly="IsReadOnlyZone"
                            ng-model="ngModelZone"
                            name="ddlZone"
                            data-placeholder="--Select Zone--" ng-click="loadAreaWiseDistributorRecords();" @*loadDistributorRecords()*@
                            style="width: 100%" ng-options="zon.ZONE_ID as zon.ZONE_NAME for zon in listZone" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ddlZone.$error.required">*</span>
            </div>

            <div class="form-group">
                <label class="col-md-4 control-label" for="input17">Distributor</label>
                <div class="col-md-6">
                    <select id="ddlDistributor" class="select2-select-00" ng-disabled="IsDisableDistributor" ng-readonly="IsReadOnlyDistributor"
                            ng-model="ngModelDistributor"
                            name="ddlDistributor"
                            data-placeholder="--Select Distributor--"
                            style="width: 100%" ng-options="dis.DIST_ID as dis.DIST_NAME for dis in listDistributor" required>
                        <option></option>
                    </select>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ddlDistributor.$error.required">*</span>
            </div>
        </div>

        <div class="col-md-6">

            <fieldset style="margin-bottom: 20px;">
                <legend style="margin-bottom:0; font-size:14px; font-weight:bold">Previous Period:</legend>
                <div class="form-group">
                    <label class="col-md-4 control-label" style="font-weight:normal"> From Date </label>
                    <div class="col-md-6">
                        <input type="text"
                               id="dtPrevStartDate"
                               class="form-control datepicker"
                               name="dtPrevStartDate" ng-model="PrevStartDate" required />
                    </div>
                    <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.dtPrevStartDate.$error.required">*</span>
                </div>

                <div class="form-group">
                    <label class="col-md-4 control-label" style="font-weight:normal"> To Date </label>
                    <div class="col-md-6">
                        <input type="text"
                               id="dtPrevEndDate"
                               class="form-control datepicker"
                               name="dtPrevEndDate" ng-model="PrevEndDate" required />
                    </div>
                    <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.dtPrevEndDate.$error.required">*</span>
                </div>
            </fieldset>

            <fieldset>
                <legend style="margin-bottom:0; font-size:14px; font-weight:bold">Current Period:</legend>
                <div class="form-group">
                    <label class="col-md-4 control-label" style="font-weight:normal"> From Date </label>
                    <div class="col-md-6">
                        <input type="text"
                               id="dtPostStartDate"
                               class="form-control datepicker"
                               name="dtPostStartDate" ng-model="PostStartDate" required />
                    </div>
                    <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.dtPostStartDate.$error.required">*</span>
                </div>

                <div class="form-group">
                    <label class="col-md-4 control-label" style="font-weight:normal"> To Date </label>
                    <div class="col-md-6">
                        <input type="text"
                               id="dtPostEndDate"
                               class="form-control datepicker"
                               name="dtPostEndDate" ng-model="PostEndDate" required />
                    </div>
                    <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.dtPostEndDate.$error.required">*</span>
                </div>
            </fieldset>


        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="form-group">
                <label class="col-md-2 control-label" for="input17"> Report Type</label>
                <div class="col-md-10">
                    <input type="radio" id="AreaBrand" ng-model="ReportType" value="AreaBrand"><label for="AreaBrand" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Area Wise Brand</label>
                    <input type="radio" id="AreaDBBrand" ng-model="ReportType" value="AreaDBBrand"><label for="AreaDBBrand" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Area Wise Brand(DB)</label>
                    <input type="radio" id="AreaBrandDtl" ng-model="ReportType" value="AreaBrandDtl"><label for="AreaBrandDtl" class="control-label" style="font-weight:normal; margin-right:10px">&nbsp;Area Wise Brand(DTL)</label>
                </div>
                <span class="error" ng-show="(frmMonthwiseSalesDelivery.$dirty||submitted) && frmMonthwiseSalesDelivery.ReportType.$error.required">*</span>
            </div>
        </div>
    </div>

</form>
